<%- layout('layouts/boilerplate') %>

<h3 id="newHeading">Create New Listing</h3>
<% if(typeof msg !== 'undefined') { %>

    <div class="alert alert-danger w-75 new-alert">
        <%= msg %>
    </div>

<% } %>
<form action="/listings" method="post" class="newListing d-flex flex-column needs-validation" novalidate>
    <div class="mb-3">
        <label for="newTitle" class="form-label ">Property name</label>
        <input type="text" class="form-control" id="newTitle" placeholder="Property  name" name="title" required>
        <div class="invalid-feedback">Please enter the property name.</div>
    </div>
    <div class="mb-3">
        <label for="newDescription" class="form-label">Description</label>
        <textarea name="description" id="newDescription" class="form-control" placeholder="Describe the property."></textarea>
    </div>
    <div class="mb-3">
        <label for="newImage" class="form-label">Image url</label>
        <input type="url" class="form-control" id="newImage" placeholder="Image URL" name="image">
    </div>
    <div class="mb-3">
        <label for="newPrice" class="form-label" >Price</label>
        <input type="number" class="form-control" id="newPrice" placeholder="Pricing" name="price" required>
    <div class="invalid-feedback">Please enter a valid price.</div>
    </div>
    <div class="new-item1 d-flex justify-content-evenly">
        
        <div class="mb-3">
            <label for="newLocation" class="form-label">Location</label>
            <input type="text" class="form-control" id="newLocation" placeholder="Location" name="location" required>
            <div class="invalid-feedback">Please enter a valid location.</div>
        </div>
        <div class="mb-3">
            <label for="newCountry" class="form-label">Country</label>
            <input type="text" class="form-control" id="newCountry" placeholder="Country" name="country" required>
        <div class="invalid-feedback">Please enter a valid country name.</div>
        </div>
    </div>
    <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="exampleCheck1" required>
        <label class="form-check-label" for="exampleCheck1">I am the sole person responsible for this property.</label>
    </div>
    <button type="submit" class="btn newPostBtn">Post Listing</button>
</form>